/target

# subagent-driven-development scratch (briefs, reports, diffs, ledger)
.superpowers/

# hegel property-testing local example database (per-machine cache, like
# Hypothesis's .hypothesis dir — not a curated regression corpus).
.hegel/

# bolero generated fuzz corpus (regenerated by the deep fuzzer; crashes are
# committed separately as regression seeds).
**/corpus/

# ...except graphics_advance's corpus, which is hand-authored realistic +
# adversarial protocol byte sequences (Kitty/Sixel/iTerm2 framing a blind
# fuzzer is very unlikely to discover on its own) meant to be committed as a
# permanent seed corpus, not regenerated noise.
!crates/emulator/tests/__fuzz__/graphics_advance/corpus/
!crates/emulator/tests/__fuzz__/graphics_advance/corpus/*

# insta pending snapshots (review with `cargo insta review`; accepted goldens
# are committed under crates/*/src/snapshots/).
*.snap.new

# cargo-mutants results output (written into the source tree at run time).
mutants.out/
mutants.out.old/
